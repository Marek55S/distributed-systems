# Ignore IntelliJ IDEA project files
.idea/
*.iml

# Ignore build outputs
out/
target/
build/

# Ignore Python virtual environments
.venv/

# Ignore Python version files
.python-version

# Ignore lock files
*.lock

# Ignore Python cache files
__pycache__/
*.pyc
*.pyo

# Ignore generated files from gRPC, Thrift, Ice, and serialization
middleware2026/workspace/grpc/gen/
middleware2026/workspace/grpc/target/
middleware2026/workspace/ice/generated/
middleware2026/workspace/ice/target/classes/
middleware2026/workspace/ice/target/generated-sources/
middleware2026/workspace/ice/target/lib/
middleware2026/workspace/serialization/gen/
middleware2026/workspace/thrift/gen-java/

# Ignore Maven and Gradle build artifacts
*.class
*.jar
*.war
*.ear
*.pom
*.log

# Ignore temporary files
*.tmp
*.swp
*.swo
.DS_Store